# Server
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://creditiq:creditiq123@localhost:5432/creditiq?schema=public

# JWT
JWT_SECRET=your-jwt-secret-replace-in-production
JWT_REFRESH_SECRET=your-refresh-secret-replace-in-production

# Email (SendGrid)
SENDGRID_API_KEY=mock

# SMS (Twilio)
TWILIO_SID=mock
TWILIO_TOKEN=mock
TWILIO_PHONE=+15005550006

# Payment (Razorpay)
RAZORPAY_KEY_ID=rzp_test_mock
RAZORPAY_KEY_SECRET=mock_secret
RAZORPAY_WEBHOOK_SECRET=mock_webhook_secret

# GSTN API
GSTN_API_KEY=mock

# Azure Storage
AZURE_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true
AZURE_STORAGE_CONTAINER_REPORTS=reports
AZURE_STORAGE_CONTAINER_UPLOADS=uploads

# Azure Key Vault
AZURE_KEY_VAULT_URL=https://creditiq-vault.vault.azure.net

# Redis (Bull queue)
REDIS_URL=redis://localhost:6379

# Encryption
ENCRYPTION_KEY=32-char-encryption-key-replace!!
